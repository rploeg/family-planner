FRONTEND_PORT=8080

# Leave empty when the frontend and backend are served through the same Portainer stack.
# The frontend will then use its own origin and the built-in Nginx proxy.
REACT_APP_API_BASE_URL=

# Set these to the public URL users will open in their browser.
CORS_ORIGIN=http://192.168.1.50:8080
GOOGLE_REDIRECT_URI=http://192.168.1.50:8080/api/google/callback

CALENDAR_SOURCE=apple
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_SYNC_INTERVAL=60
GOOGLE_TASKS_LIST_NAME=Shopping List
GOOGLE_CALENDAR_ID=primary

CALDAV_SERVER_URL=https://caldav.icloud.com
CALDAV_USERNAME=
CALDAV_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LOXONE_SERVER_URL=https://192.168.1.20
LOXONE_USERNAME=
LOXONE_PASSWORD=